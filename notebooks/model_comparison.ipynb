ax.set_ylim(0, max(accs) + 10)
ax.set_ylabel("Test Accuracy (%)")
ax.set_title("Comparison 1 — Model Test Accuracy", fontsize=13, fontweight="bold")
ax.grid(axis="y", alpha=0.3)
plt.tight_layout()
plt.savefig("compare_01_test_accuracy.png", dpi=150); plt.show()
print("Saved: compare_01_test_accuracy.png")

# ======================== ENSEMBLE ==========================
print(f"\n{'='*60}")
print(f"  Ensemble Evaluation (avg softmax of all {len(MODELS_CONFIG)} models)")
print(f"{'='*60}")

y_true_idx   = np.argmax(y_true_all, axis=1)
ensemble_avg = np.mean(list(all_probs.values()), axis=0)
y_pred_ens   = np.argmax(ensemble_avg, axis=1)
ens_acc      = np.mean(y_pred_ens == y_true_idx)
print(f"Ensemble Test Accuracy: {ens_acc*100:.2f}%")

# ── Full diagnostics for the Ensemble ───────────────────────
run_full_diagnostics(
    tag        = "Ensemble",
    y_true_idx = y_true_idx,
    y_pred     = y_pred_ens,
    y_prob     = ensemble_avg,
    class_names= CLASS_NAMES,
)

# ======================== ALL 10 COMPARISON PLOTS ===========
plot_all_comparisons(
